# === Polymarket Auth (Multiple Wallets) ===
# Format: key1:address1:sigtype1,key2:address2:sigtype2,...
# Example: 0xabc...:0x123...:0,0xdef...:0x456...:2
POLY_WALLETS=
POLYGON_RPC_URL=                # (Optional) Private Alchemy/Infura RPC URL for speed

# === Quantitative Strategy ===
EDGE_THRESHOLD=0.07             # Minimum edge to enter a trade (e.g. 0.07 = 7%)
KELLY_FRACTION=0.5              # Fraction of Kelly Criterion (0.5 = Half-Kelly)
BTC_VOLATILITY_PER_SEC=0.15     # Estimated BTC volatility per second in USD
ENTRY_SECONDS_BEFORE_CLOSE=3.0  # Entry 3s before market close
PRE_CLOSE_SELL_SECONDS=0.7      # Auto-sell 0.7s before market close
GAP_TRIGGER_USD=2.0              # Minimum gap in USD between target and live price
REDEEM_LOSSES=True             # Auto-redeem losing resolved trades to clear wallet

# === Cooldown Period ===
COOLDOWN_START_TIME=10:00        # Start time (HH:MM)
COOLDOWN_END_TIME=11:59          # End time (HH:MM)
COOLDOWN_TIMEZONE=US/Eastern     # Timezone for the window
